<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score:0" name="ScoreLabel" style="top: auto; justify-content: flex-end; width: 80px; align-self: center; height: 27px; font-size: 20px; -unity-font-style: bold; color: rgb(255, 255, 255);"/>
    <ui:Button text="Restart" name="RestartButton" style="position: absolute; top: 45%; font-size: 20px; -unity-font-style: bold; align-self: center; color: rgb(0, 232, 255); -unity-text-outline-color: rgb(255, 255, 255); visibility: visible; display: flex; background-color: rgb(0, 0, 0); -unity-background-image-tint-color: rgb(0, 0, 0); border-left-color: rgb(0, 41, 255); border-right-color: rgb(0, 41, 255); border-top-color: rgb(0, 41, 255); border-bottom-color: rgb(0, 41, 255);"/>
    <ui:Label text="High Score: 0" name="HighScore" selectable="false" focusable="false" style="-unity-text-align: upper-center; font-size: 20px; -unity-font-style: bold; position: absolute; align-self: center; top: 60%; color: rgb(0, 232, 255); -unity-background-image-tint-color: rgb(0, 0, 0); -unity-background-scale-mode: stretch-to-fill; border-top-width: 0; border-right-width: 0;"/>
</ui:UXML>
